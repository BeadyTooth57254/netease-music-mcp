# NetEase Cloud Music cookie (required for VIP songs)
# Get this from your browser after logging into music.163.com
NETEASE_COOKIE=your_cookie_here

# Or use a cookie file
NETEASE_COOKIE_FILE=./netease_cookie.txt

# Server ports
MCP_PORT=3456
API_PORT=3457

# Auth token for API
AUTH_TOKEN=changeme

# MCP token
MCP_TOKEN=your-mcp-token

# SQLite database path
MUSIC_DB_PATH=./music.db

# NetEase proxy URL (NeteaseCloudMusicApi)
NETEASE_PROXY=http://127.0.0.1:3460
